
{% liquid
  assign label = block.settings.label
  assign preset = block.settings.icon_preset
  assign radio_id = 'contact-reason-' | append: block.id
  assign radio_value = label | handleize
-%}

<label class="contact-reason" for="{{ radio_id }}" {{ block.shopify_attributes }}>
  <input
    type="radio"
    id="{{ radio_id }}"
    name="contact[topic]"
    value="{{ radio_value }}"
    class="contact-reason__input"
  >
  <span class="contact-reason__icon" aria-hidden="true">
    {%- if block.settings.icon != blank -%}
      {{
        block.settings.icon
        | image_url: width: 120
        | image_tag:
          loading: 'lazy',
          widths: '60, 120, 180',
          sizes: '40px',
          alt: ''
      }}
    {%- elsif preset == 'cart' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h2l2.4 11.2a2 2 0 0 0 2 1.6h7.6a2 2 0 0 0 2-1.5L21 9H6"/><circle cx="10" cy="21" r="1.2" fill="currentColor"/><circle cx="17" cy="21" r="1.2" fill="currentColor"/></svg>
    {%- elsif preset == 'truck' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7"/><circle cx="7" cy="18" r="1.6" fill="currentColor"/><circle cx="17" cy="18" r="1.6" fill="currentColor"/></svg>
    {%- elsif preset == 'alert' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5"/><circle cx="12" cy="16.5" r="1" fill="currentColor" stroke="none"/></svg>
    {%- elsif preset == 'bottle' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3h4v3l1.5 2.5A4 4 0 0 1 16 11v8a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-8a4 4 0 0 1 .5-2.5L10 6V3z"/><path d="M10 14h4"/></svg>
    {%- elsif preset == 'briefcase' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M9 7V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/><path d="M3 13h18"/></svg>
    {%- elsif preset == 'chat' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a8 8 0 0 1-12.5 6.7L4 20l1.3-4.5A8 8 0 1 1 21 12z"/></svg>
    {%- elsif preset == 'mail' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 7 9-7"/></svg>
    {%- elsif preset == 'phone' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16.5v3a2 2 0 0 1-2.2 2 19 19 0 0 1-8.3-3 19 19 0 0 1-6-6A19 19 0 0 1 1.5 4.2 2 2 0 0 1 3.5 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.7.6 2.5a2 2 0 0 1-.5 2.1L7.5 9.5a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.6.5 2.5.6a2 2 0 0 1 1.7 2z"/></svg>
    {%- elsif preset == 'tag' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.6 13.4 13 21l-9-9V4h8l8.6 8.6a1 1 0 0 1 0 1.4z"/><circle cx="8" cy="8" r="1.4" fill="currentColor" stroke="none"/></svg>
    {%- elsif preset == 'question' -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.5 9.5a2.5 2.5 0 0 1 5 0c0 1.5-2.5 2-2.5 3.5"/><circle cx="12" cy="17" r="1" fill="currentColor" stroke="none"/></svg>
    {%- else -%}
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5"/><circle cx="12" cy="16.5" r="1" fill="currentColor" stroke="none"/></svg>
    {%- endif -%}
  </span>
  <span class="contact-reason__label">{{ label }}</span>
  <span class="contact-reason__check" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 7"/></svg>
  </span>
</label>

{% schema %}
{
  "name": "Contact reason",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "BESTELLEN & BETALEN"
    },
    {
      "type": "select",
      "id": "icon_preset",
      "label": "Icon",
      "options": [
        { "value": "cart", "label": "Shopping cart" },
        { "value": "truck", "label": "Delivery truck" },
        { "value": "alert", "label": "Alert / problem" },
        { "value": "bottle", "label": "Bottle / product" },
        { "value": "briefcase", "label": "Briefcase / B2B" },
        { "value": "chat", "label": "Chat bubble" },
        { "value": "mail", "label": "Mail" },
        { "value": "phone", "label": "Phone" },
        { "value": "tag", "label": "Tag / pricing" },
        { "value": "question", "label": "Question mark" }
      ],
      "default": "cart"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Custom icon (overrides preset)",
      "info": "Optional. Uploaded icons are recolored to the icon color via CSS filter."
    }
  ],
  "presets": [
    {
      "name": "Contact reason"
    }
  ]
}
{% endschema %}
