{%- liquid
  assign rip_height = block.settings.rip_height | default: 12
  assign rip_angle = block.settings.rip_angle | default: 0
  assign rip_scale = block.settings.rip_scale | default: 100
  assign rip_offset = block.settings.rip_offset | default: 0
  assign rip_flip = block.settings.flip_horizontal
  assign rip_image = block.settings.image_url | default: 'https://cdn.shopify.com/s/files/1/0975/9247/5912/files/scheurlijn_silver.svg?v=1767843076'
-%}

<div
  class="hero-rip-block"
  style="
    --rip-height: {{ rip_height }}%;
    --rip-angle: {{ rip_angle }}deg;
    --rip-scale: {{ rip_scale }};
    --rip-offset: {{ rip_offset }}px;
    --rip-flip: {% if rip_flip %}-1{% else %}1{% endif %};
  "
  {{ block.shopify_attributes }}
>
  <img
    class="hero-rip-block__img"
    src="{{ rip_image }}"
    alt=""
    width="1200"
    height="146"
    loading="lazy"
    decoding="async"
    fetchpriority="low"
  >
</div>

{% style %}
  .hero-rip-block {
    position: absolute;
    left: 50%;
    width: 100vw;
    max-width: none;
    bottom: 0;
    height: var(--rip-height, 12%);
    transform-origin: 50% 100%;
    transform: translate(-50%, var(--rip-offset, 0px)) rotate(var(--rip-angle, 0deg));
    pointer-events: none;
    z-index: var(--layer-overlay);
    overflow: visible;
  }

  .hero-rip-block__img {
    width: 100%;
    height: 100%;
    display: block;
    transform-origin: 50% 100%;
    transform: scaleX(var(--rip-flip, 1)) scale(calc(var(--rip-scale, 100) / 100));
    object-fit: cover;
    object-position: center;
  }

  @media screen and (max-width: 749px) {
    .hero-rip-block {
      height: calc(var(--rip-height, 12%) * 1.15);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Ripped paper edge",
  "tag": "div",
  "class": "hero-rip-block__container",
  "settings": [
    {
      "type": "url",
      "id": "image_url",
      "label": "SVG URL",
      "info": "Leave blank to use the uploaded scheurlijn_silver.svg"
    },
    {
      "type": "range",
      "id": "rip_height",
      "label": "Height (% of hero)",
      "min": 4,
      "max": 30,
      "step": 1,
      "unit": "%",
      "default": 12
    },
    {
      "type": "range",
      "id": "rip_angle",
      "label": "Angle (deg)",
      "min": -15,
      "max": 15,
      "step": 1,
      "unit": "°",
      "default": 0
    },
    {
      "type": "range",
      "id": "rip_scale",
      "label": "Scale (%)",
      "min": 50,
      "max": 150,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "rip_offset",
      "label": "Vertical offset (px)",
      "min": -120,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "flip_horizontal",
      "label": "Flip horizontally",
      "default": false
    }
  ]
}
{% endschema %}

