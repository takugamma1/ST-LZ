
{% liquid
  assign step_number = block.settings.step_number
  if step_number == blank
    assign step_number = forloop.index
  endif

  assign step_number_str = step_number | append: ''
  assign step_number_pad = step_number_str
  if step_number < 10
    assign step_number_pad = '0' | append: step_number
  endif
-%}

<div
  class="hiw-step"
  style="--hiw-step-tint: {{ block.settings.tint_color }};"
  {{ block.shopify_attributes }}
>
  <div class="hiw-step__media">
    {%- if block.settings.image != blank -%}
      {{
        block.settings.image
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          widths: '300, 500, 700, 900, 1200',
          sizes: '(min-width: 1100px) 22vw, (min-width: 750px) 24vw, 45vw',
          class: 'hiw-step__image',
          alt: block.settings.title
      }}
    {%- else -%}
      <div class="hiw-step__image hiw-step__image--placeholder">
        <span>{{ step_number_pad }}</span>
      </div>
    {%- endif -%}

    <div class="hiw-step__gradient" aria-hidden="true"></div>

    <span class="hiw-step__number{% if section.settings.number_stroke_width == 0 %} hiw-step__number--solid{% endif %}" aria-hidden="true">{{ step_number_pad }}</span>

    {%- if block.settings.title != blank -%}
      <h3 class="hiw-step__title">{{ block.settings.title }}</h3>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "How-it-works step",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (3:2 recommended)"
    },
    {
      "type": "text",
      "id": "step_number",
      "label": "Step number override",
      "info": "Leave blank to auto-number."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Kies je product"
    },
    {
      "type": "color",
      "id": "tint_color",
      "label": "Gradient color",
      "info": "Color of the gradient at the bottom of the image.",
      "default": "#0c1a3a"
    }
  ],
  "presets": [
    {
      "name": "How-it-works step"
    }
  ]
}
{% endschema %}
