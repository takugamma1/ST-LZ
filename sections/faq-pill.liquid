
{% liquid
  assign heading_class = 'faq-pill__heading faq-pill__heading--' | append: section.settings.heading_style
-%}

<div class="section-background faq-pill__background" style="background: {{ section.settings.section_bg_color }};"></div>

<div
  class="
    faq-pill
    section
    section--{{ section.settings.section_width }}
    spacing-style
    faq-pill--heading-{{ section.settings.heading_style }}
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    --faq-section-bg: {{ section.settings.section_bg_color }};
    --faq-heading-color: {{ section.settings.heading_color }};
    --faq-heading-stroke: {{ section.settings.heading_stroke_width }}px;
    --faq-button-bg: {{ section.settings.button_bg }};
    --faq-button-fg: {{ section.settings.button_fg }};
    --faq-button-border: {{ section.settings.button_border }};
    --faq-button-border-width: {{ section.settings.button_border_width }}px;
    --faq-button-radius: {{ section.settings.button_radius }}px;
    --faq-button-gap: {{ section.settings.button_gap }}px;
    --faq-answer-bg: {{ section.settings.answer_bg }};
    --faq-answer-fg: {{ section.settings.answer_fg }};
    --faq-open-duration: {{ section.settings.open_duration }}ms;
  "
>
  <div class="faq-pill__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="{{ heading_class }}">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="faq-pill__list">
      {%- content_for 'blocks' -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* Section background fills full width (not just the content) */
  .faq-pill {
    position: relative;
  }

  .faq-pill__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* --- Heading variants ----------------------------------------- */

  .faq-pill__heading {
    margin: 0;
    text-align: center;
    text-transform: uppercase;
    line-height: 0.95;
    letter-spacing: 0.02em;
    font-weight: 900;
    font-size: clamp(2.5rem, 9cqi, 6rem);
  }

  .faq-pill__heading--solid {
    color: var(--faq-heading-color, #ffffff);
  }

  .faq-pill__heading--outline {
    color: transparent;
    -webkit-text-stroke: var(--faq-heading-stroke, 2px) var(--faq-heading-color, #ffffff);
    paint-order: stroke fill;
  }

  /* --- List & rows ---------------------------------------------- */

  .faq-pill__list {
    display: flex;
    flex-direction: column;
    gap: var(--faq-button-gap, 12px);
  }

  .faq-pill__item {
    background: transparent;
  }

  /* Hide default disclosure marker across browsers */
  .faq-pill__item summary {
    list-style: none;
  }
  .faq-pill__item summary::-webkit-details-marker {
    display: none;
  }
  .faq-pill__item summary::marker {
    display: none;
    content: '';
  }

  .faq-pill__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    padding: 18px 28px;
    background: var(--faq-button-bg, #ffffff);
    color: var(--faq-button-fg, #0c1a3a);
    border-radius: var(--faq-button-radius, 999px);
    border-width: var(--faq-button-border-width, 0);
    border-style: solid;
    border-color: var(--faq-button-border, transparent);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    user-select: none;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }

  .faq-pill__question:hover {
    filter: brightness(0.97);
  }

  .faq-pill__question:active {
    transform: translateY(1px);
  }

  .faq-pill__question-text {
    flex: 1;
    min-width: 0;
  }

  .faq-pill__question-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    transition: transform var(--faq-open-duration, 500ms) cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-pill__question-icon svg {
    width: 100%;
    height: 100%;
  }

  .faq-pill__item[open] .faq-pill__question-icon {
    transform: rotate(180deg);
  }

  /* --- Smooth open animation using grid-template-rows trick ----- */

  .faq-pill__answer-outer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--faq-open-duration, 500ms) cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-pill__item[open] .faq-pill__answer-outer {
    grid-template-rows: 1fr;
  }

  .faq-pill__answer-inner {
    overflow: hidden;
    min-height: 0;
    background: var(--faq-answer-bg, transparent);
    color: var(--faq-answer-fg, inherit);
    border-radius: 18px;
    margin-top: 6px;
    padding: 18px 28px;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .faq-pill__answer-inner > *:first-child {
    margin-top: 0;
  }

  .faq-pill__answer-inner > *:last-child {
    margin-bottom: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ pill",
  "tag": "section",
  "class": "faq-pill-wrapper section-wrapper",
  "blocks": [
    {
      "type": "faq-pill-item"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FREQUENTLY ASKED QUESTIONS"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading style",
      "options": [
        { "value": "outline", "label": "Outlined" },
        { "value": "solid", "label": "Solid fill" }
      ],
      "default": "outline"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_stroke_width",
      "label": "Outline thickness (outlined only)",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Section background"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background",
      "default": "#0c1a3a"
    },
    {
      "type": "header",
      "content": "Question buttons"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_fg",
      "label": "Button text color",
      "default": "#0c1a3a"
    },
    {
      "type": "color",
      "id": "button_border",
      "label": "Button border color",
      "default": "#0c1a3a"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Button border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 60,
      "info": "Set to 60 for a full pill shape."
    },
    {
      "type": "range",
      "id": "button_gap",
      "label": "Gap between buttons",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Answer panel"
    },
    {
      "type": "color",
      "id": "answer_bg",
      "label": "Answer background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "answer_fg",
      "label": "Answer text color",
      "default": "#0c1a3a"
    },
    {
      "type": "range",
      "id": "open_duration",
      "label": "Open / close duration",
      "min": 200,
      "max": 1200,
      "step": 50,
      "unit": "ms",
      "default": 600
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "FAQ pill",
      "category": "Text",
      "blocks": [
        {
          "type": "faq-pill-item",
          "settings": {
            "question": "Wat is het retourbeleid?",
            "answer": "<p>Ons doel is dat elke klant volledig tevreden is met zijn aankoop. Als dit niet het geval is, laat het ons dan weten.</p>"
          }
        },
        {
          "type": "faq-pill-item",
          "settings": {
            "question": "Zijn bepaalde aankopen definitief?",
            "answer": "<p>We kunnen bepaalde artikelen niet retour nemen. Dit wordt vóór de aankoop duidelijk aangegeven.</p>"
          }
        },
        {
          "type": "faq-pill-item",
          "settings": {
            "question": "Wanneer ontvang ik mijn bestelling?",
            "answer": "<p>We zullen je bestelling zo snel mogelijk verzenden. Zodra je bestelling is verzonden, ontvang je een e-mail met meer informatie.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
