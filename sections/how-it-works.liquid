
<div class="section-background hiw-section__background" style="background: {{ section.settings.section_bg_color }};"></div>

<div
  class="
    hiw-section
    section
    section--{{ section.settings.section_width }}
    spacing-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    --hiw-fg: {{ section.settings.text_color }};
    --hiw-image-radius: {{ section.settings.image_radius }}px;
    --hiw-columns: {{ section.settings.columns_desktop }};
    --hiw-gap: {{ section.settings.card_gap }}px;
    --hiw-mobile-card-width: {{ section.settings.mobile_card_width }};
    --hiw-aspect: {{ section.settings.image_aspect }};
    --hiw-gradient-percent: {{ section.settings.gradient_percent }}%;
    --hiw-gradient-opacity: {{ section.settings.gradient_opacity | divided_by: 100.0 }};
    --hiw-overlay-color: {{ section.settings.overlay_text_color }};
    --hiw-number-color: {{ section.settings.number_color }};
    --hiw-number-stroke: {{ section.settings.number_stroke_width }}px;
  "
>
  <div class="hiw-section__inner">
    {%- if section.settings.heading != blank -%}
      {%- render 'outlined-heading',
        text: section.settings.heading,
        color: section.settings.heading_color,
        stroke_width: section.settings.heading_stroke,
        size: section.settings.heading_size,
        align: 'center',
        tag: 'h2',
        solid: section.settings.heading_solid,
        solid_color: section.settings.heading_color
      -%}
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hiw-section__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="hiw-grid">
      {%- content_for 'blocks' -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hiw-section {
    position: relative;
    color: var(--hiw-fg, #0c1a3a);
    container-type: inline-size;
  }

  .hiw-section__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .hiw-section__subheading {
    margin: 0;
    text-align: center;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--hiw-fg, #0c1a3a);
    opacity: 0.8;
    max-width: 60ch;
  }

  /* Mobile: horizontal scroll-snap carousel. Desktop: grid. */
  .hiw-grid {
    display: flex;
    gap: var(--hiw-gap, 16px);
    width: 100%;
    margin-top: 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: var(--hiw-edge-padding, 16px);
    padding-inline: var(--hiw-edge-padding, 16px);
    margin-inline: calc(var(--hiw-edge-padding, 16px) * -1);
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .hiw-grid::-webkit-scrollbar {
    display: none;
  }

  .hiw-grid > * {
    flex: 0 0 var(--hiw-mobile-card-width, 80cqw);
    scroll-snap-align: start;
  }

  @media (min-width: 750px) {
    .hiw-grid {
      display: grid;
      grid-template-columns: repeat(var(--hiw-columns, 4), minmax(0, 1fr));
      overflow: visible;
      padding-inline: 0;
      margin-inline: 0;
    }

    .hiw-grid > * {
      flex: initial;
    }
  }

  /* --- Step ------------------------------------------------ */

  .hiw-step {
    display: flex;
    flex-direction: column;
    background: transparent;
    height: 100%;
  }

  .hiw-step__media {
    position: relative;
    aspect-ratio: var(--hiw-aspect, 3 / 2);
    overflow: hidden;
    border-radius: var(--hiw-image-radius, 8px);
    background: transparent;
    isolation: isolate;
  }

  .hiw-step__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hiw-step__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-size: clamp(2rem, 8cqi, 4rem);
    font-weight: 900;
    color: var(--hiw-fg, #0c1a3a);
    opacity: 0.25;
    background: rgb(0 0 0 / 0.04);
  }

  .hiw-step__gradient {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: var(--hiw-gradient-percent, 40%);
    background: linear-gradient(
      to top,
      var(--hiw-step-tint, transparent),
      transparent
    );
    opacity: var(--hiw-gradient-opacity, 1);
    pointer-events: none;
    z-index: 1;
  }

  /* Step number positioned in opposite corner from title (top-right) */
  .hiw-step__number {
    position: absolute;
    top: 12px;
    right: 14px;
    z-index: 3;
    margin: 0;
    font-family: var(--font-heading--family, inherit);
    font-weight: 900;
    font-size: clamp(2rem, 6cqi, 4rem);
    line-height: 0.85;
    letter-spacing: -0.02em;
    color: transparent;
    -webkit-text-stroke: var(--hiw-number-stroke, 2px) var(--hiw-number-color, #ffffff);
    paint-order: stroke fill;
    pointer-events: none;
    user-select: none;
  }

  .hiw-step__number--solid {
    color: var(--hiw-number-color, #ffffff);
    -webkit-text-stroke: 0;
  }

  /* Title pinned to bottom-left, inside the image, over the gradient */
  .hiw-step__title {
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 14px;
    z-index: 2;
    margin: 0;
    font-size: clamp(0.9rem, 1.6cqi, 1.15rem);
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--hiw-overlay-color, #ffffff);
    line-height: 1.2;
    text-align: left;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.18);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "How it works",
  "tag": "section",
  "class": "hiw-section-wrapper section-wrapper",
  "blocks": [
    {
      "type": "how-it-works-step"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "HOW IT WORKS"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "xs", "label": "Extra small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ],
      "default": "md"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#0c1a3a"
    },
    {
      "type": "checkbox",
      "id": "heading_solid",
      "label": "Solid (filled) heading instead of outlined",
      "default": false
    },
    {
      "type": "range",
      "id": "heading_stroke",
      "label": "Outline thickness",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Vier eenvoudige stappen om je gepersonaliseerde shirt te bestellen."
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "mobile_card_width",
      "label": "Mobile card width",
      "info": "Width of each card in the mobile horizontal carousel.",
      "options": [
        { "value": "85cqw", "label": "One per screen (peek)" },
        { "value": "65cqw", "label": "~1.5 per screen" },
        { "value": "48cqw", "label": "Two per screen" }
      ],
      "default": "65cqw"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between steps",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_aspect",
      "label": "Image aspect ratio",
      "options": [
        { "value": "3 / 2", "label": "3:2 (landscape)" },
        { "value": "1 / 1", "label": "1:1 (square)" },
        { "value": "4 / 5", "label": "4:5 (portrait)" },
        { "value": "16 / 9", "label": "16:9 (wide)" }
      ],
      "default": "3 / 2"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Overlay (text on image)"
    },
    {
      "type": "color",
      "id": "overlay_text_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Step number color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "number_stroke_width",
      "label": "Step number outline thickness",
      "info": "Set to 0 for a solid filled number instead of outlined.",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Bottom gradient"
    },
    {
      "type": "range",
      "id": "gradient_percent",
      "label": "Gradient height",
      "info": "How much of the image bottom is covered by the gradient.",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "range",
      "id": "gradient_opacity",
      "label": "Gradient strength",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70
    },
    {
      "type": "header",
      "content": "Section appearance"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0c1a3a"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "How it works",
      "category": "Text",
      "blocks": [
        { "type": "how-it-works-step", "settings": { "title": "Kies je product", "tint_color": "#f5d6b3" } },
        { "type": "how-it-works-step", "settings": { "title": "Upload je logo", "tint_color": "#cfe0d2" } },
        { "type": "how-it-works-step", "settings": { "title": "Wij printen het", "tint_color": "#f5e3b3" } },
        { "type": "how-it-works-step", "settings": { "title": "Geleverd aan huis", "tint_color": "#d6dbe8" } }
      ]
    }
  ]
}
{% endschema %}
