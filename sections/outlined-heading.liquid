
<div class="section-background outlined-heading-section__background" style="background: {{ section.settings.section_bg_color }};"></div>

<div
  class="
    outlined-heading-section
    section
    section--{{ section.settings.section_width }}
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {%- render 'outlined-heading',
    text: section.settings.text,
    color: section.settings.text_color,
    stroke_width: section.settings.stroke_width,
    size: section.settings.size,
    align: section.settings.alignment,
    tag: section.settings.tag,
    solid: section.settings.solid,
    solid_color: section.settings.text_color
  -%}
</div>

{% schema %}
{
  "name": "Outlined heading",
  "tag": "section",
  "class": "outlined-heading-section-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "THE STËLZ COMMUNITY"
    },
    {
      "type": "select",
      "id": "size",
      "label": "Size",
      "options": [
        { "value": "xs", "label": "Extra small" },
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra large" },
        { "value": "xxl", "label": "Hero" }
      ],
      "default": "xl"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "tag",
      "label": "HTML tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "div", "label": "Div" }
      ],
      "default": "h2"
    },
    {
      "type": "checkbox",
      "id": "solid",
      "label": "Solid fill (instead of outlined)",
      "default": false
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "stroke_width",
      "label": "Outline thickness",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background",
      "default": "#0c1a3a"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Outlined heading",
      "category": "Text"
    }
  ]
}
{% endschema %}
