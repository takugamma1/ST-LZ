                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_8WqLed": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Ons doel is dat elke klant volledig tevreden is met zijn aankoop. Als dit niet het geval is, laat het ons dan weten. We doen ons best om samen met jou tot een goede oplossing te komen.</p>",
                    "width": "100%",
