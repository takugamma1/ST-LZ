                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_pTjnPR": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We kunnen bepaalde artikelen niet retour nemen. Dit wordt vóór de aankoop duidelijk aangegeven.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
