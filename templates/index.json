              "blocks": {
                "text_KK3fbW": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>We zullen je bestelling zo snel mogelijk verzenden. Zodra je bestelling is verzonden, ontvang je een e-mail met meer informatie. De levertijden zijn afhankelijk van je locatie.</p>",
                    "width": "100%",
                    "max_width": "normal",
